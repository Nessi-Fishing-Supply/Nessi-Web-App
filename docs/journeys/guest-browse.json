{
  "slug": "guest-browse",
  "title": "Guest Browse & Discover",
  "persona": "guest",
  "description": "Unauthenticated user browses the marketplace by category, keyword search, or featured listings. Views listing details, seller profiles, and shop pages.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "browse-by-category",
      "title": "Browse by Category",
      "trigger": "Guest clicks a category on the homepage",
      "steps": [
        {
          "id": "land-homepage",
          "label": "Guest lands on homepage",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "click-category",
          "label": "Click a category link",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "category-page",
          "label": "Navigate to /category/[slug]",
          "layer": "client",
          "status": "built",
          "route": "/category/[slug]"
        },
        {
          "id": "apply-filters",
          "label": "Filter: condition, price, state, species, listing type",
          "layer": "client",
          "status": "built",
          "notes": "All filters stored in URL params (shareable)."
        },
        {
          "id": "infinite-scroll",
          "label": "Infinite scroll results",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "click-listing",
          "label": "Click listing card",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "listing-detail",
          "label": "View listing detail at /listing/[id]",
          "layer": "client",
          "status": "built",
          "route": "/listing/[id]"
        },
        {
          "id": "view-count",
          "label": "View count incremented",
          "layer": "server",
          "status": "built"
        }
      ]
    },
    {
      "id": "search-by-keyword",
      "title": "Search by Keyword",
      "trigger": "Guest types in search bar",
