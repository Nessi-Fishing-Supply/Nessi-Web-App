        {
          "id": "type-search",
          "label": "Type in search bar",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "autocomplete",
          "label": "Autocomplete suggestions appear (3+ chars, 200ms debounce)",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "select-or-enter",
          "label": "Select suggestion or press Enter",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "search-results",
          "label": "Navigate to /search?q=...",
          "layer": "client",
          "status": "built",
          "route": "/search"
        },
        {
          "id": "filter-results",
          "label": "Apply filters: condition, price, state, species, listing type",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "scroll-results",
          "label": "Infinite scroll results",
          "layer": "client",
          "status": "built"
        }
      ]
    },
    {
      "id": "view-profiles",
      "title": "View Seller & Shop Profiles",
      "trigger": "Guest clicks seller or shop link on listing detail",
      "steps": [
        {
          "id": "click-seller",
          "label": "Click seller profile link on listing detail",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "member-page",
          "label": "View seller profile at /member/[slug]",
          "layer": "client",
          "status": "built",
          "route": "/member/[slug]"
        },
        {
          "id": "seller-listings",
          "label": "See seller's other listings",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "click-shop",
          "label": "Click shop page link on listing detail",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "shop-page",
          "label": "View shop page at /shop/[slug]",
          "layer": "client",
          "status": "built",
          "route": "/shop/[slug]"
        },
        {
          "id": "shop-listings",
          "label": "See shop's listings grid + hero banner",
          "layer": "client",
          "status": "built"
        }
