{
  "slug": "buyer-cart",
  "title": "Authenticated Cart (DB-Backed)",
  "persona": "buyer",
  "description": "Authenticated buyer adds items to DB-backed cart with price snapshots, 30-day expiry, seller grouping, and pre-checkout validation.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "add-to-cart",
      "title": "Add Item to Cart",
      "trigger": "Buyer clicks 'Add to Cart' on listing detail page",
      "steps": [
        {
          "id": "click-add",
          "label": "Buyer clicks 'Add to Cart' button",
          "layer": "client",
          "status": "built",
          "errorCases": [
            { "condition": "Own listing", "result": "Button disabled" },
            { "condition": "Already in cart", "result": "Button shows 'In Cart'" },
            { "condition": "Cart has 25 items", "result": "Toast: cart full" }
          ]
        },
        {
          "id": "post-cart",
          "label": "POST /api/cart (listingId, priceCents)",
          "layer": "server",
          "status": "built",
          "route": "POST /api/cart"
        },
        {
          "id": "price-snapshot",
          "label": "Price snapshot saved as price_at_add",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "set-expiry",
          "label": "30-day expiry TTL set",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "optimistic-update",
          "label": "Optimistic cache update",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "show-toast",
          "label": "Toast: Added to cart",
          "layer": "client",
          "status": "built"
        }
      ]
    },
    {
      "id": "view-cart",
      "title": "View Cart",
      "trigger": "Buyer navigates to /cart",
      "steps": [
        {
          "id": "fetch-cart",
          "label": "GET /api/cart (items + listing data)",
          "layer": "server",
          "status": "built",
          "route": "GET /api/cart"
        },
        {
          "id": "group-by-seller",
          "label": "Items grouped by seller",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "show-item-states",
          "label": "Show item states: valid, price changed (old vs new), removed/sold (warning)",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "cart-actions",
          "label": "Actions: remove item, clear all, refresh expiry",
          "layer": "client",
          "status": "built"
        }
      ],
      "connections": [
        { "from": "cart-actions", "to": "remove-item", "label": "Remove" },
        { "from": "cart-actions", "to": "clear-all", "label": "Clear" },
        { "from": "cart-actions", "to": "refresh-expiry", "label": "Refresh" }
      ]
    },
    {
      "id": "cart-actions",
      "title": "Cart Item Actions",
      "trigger": "Buyer interacts with cart items",
      "steps": [
        {
          "id": "remove-item",
          "label": "Remove item — DELETE /api/cart/[id]",
          "layer": "server",
          "status": "built",
          "route": "DELETE /api/cart/[id]"
        },
        {
          "id": "clear-all",
          "label": "Clear all — DELETE /api/cart",
          "layer": "server",
          "status": "built",
          "route": "DELETE /api/cart"
        },
        {
          "id": "refresh-expiry",
          "label": "Refresh expiry — PATCH /api/cart/[id]/expiry",
          "layer": "server",
          "status": "built",
          "route": "PATCH /api/cart/[id]/expiry"
        }
      ]
    },
    {
      "id": "pre-checkout-validation",
      "title": "Pre-Checkout Validation",
      "trigger": "Buyer initiates checkout",
      "steps": [
        {
          "id": "validate-cart",
          "label": "POST /api/cart/validate",
          "layer": "server",
          "status": "built",
          "route": "POST /api/cart/validate"
        },
        {
          "id": "handle-result",
          "label": "Handle validation result",
          "layer": "client",
          "status": "built"
        }
      ],
      "branches": [
        {
          "afterStep": "validate-cart",
          "condition": "Validation result?",
          "paths": [
            { "label": "Valid — proceed to checkout", "goTo": "END" },
            { "label": "Price changed — acknowledge changes", "goTo": "END" },
            { "label": "Removed — items auto-removed", "goTo": "END" }
          ]
        }
      ]
    }
  ]
}
