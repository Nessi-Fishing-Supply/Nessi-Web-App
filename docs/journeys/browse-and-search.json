{
  "slug": "browse-and-search",
  "domain": "shopping",
  "title": "Browse & Search Listings",
  "persona": "buyer",
  "description": "Users discover listings via category browsing, keyword search with autocomplete, or featured/homepage. Includes filters, infinite scroll, view tracking, and recently viewed. Guest and authenticated paths diverge at view tracking and watchlist access.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "discover",
      "title": "Discover Listings",
      "trigger": "User lands on Nessi marketplace",
      "steps": [
        {
          "id": "land-on-site",
          "title": "Land on Homepage",
          "layer": "client",
          "status": "built",
          "tooltip": "User arrives at Nessi homepage. Sees featured listings, categories, and search bar."
        }
      ],
      "branches": [
        {
          "afterStep": "land-on-site",
          "condition": "How do they discover?",
          "paths": [
            { "label": "Browse Category", "goTo": "land-homepage" },
            { "label": "Search", "goTo": "type-query" },
            { "label": "View Profile", "goTo": "click-seller" }
          ]
        }
      ]
    },
    {
      "id": "browse-by-category",
      "title": "Browse by Category",
      "trigger": "User clicks a category on the homepage",
      "steps": [
        {
          "id": "land-homepage",
          "title": "Land on Homepage",
          "action": "navigate",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "click-category",
          "title": "Click Category",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "category-page",
          "title": "View Category Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/category/[slug]"
        },
        {
          "id": "apply-filters",
          "title": "Apply Filters",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Filter: condition, price, state, species, listing type. All filters stored in URL params (shareable)."
        },
        {
          "id": "infinite-scroll",
          "title": "Scroll Results",
          "action": "scroll",
          "layer": "client",
          "status": "built",
          "tooltip": "Infinite scroll pagination"
        },
        {
          "id": "click-listing",
          "title": "Click Listing Card",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "listing-detail",
          "title": "View Listing Detail",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/listing/[id]"
        },
        {
          "id": "view-count",
          "title": "Increment View Count",
          "layer": "server",
          "status": "built",
          "tooltip": "View count incremented on listing detail page load"
        }
      ]
    },
    {
      "id": "search",
      "title": "Search with Autocomplete",
      "trigger": "User types in search bar",
      "steps": [
        {
          "id": "type-query",
          "title": "Type Search Query",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Type 3+ chars triggers autocomplete with 200ms debounce"
        },
        {
          "id": "suggestion-sources",
          "title": "Fetch Suggestions",
          "layer": "server",
          "status": "built",
          "tooltip": "Suggestions from popular search terms, listing titles, category names"
        },
        {
          "id": "select-or-enter",
          "title": "Select or Submit",
          "action": "submit",
          "layer": "client",
          "status": "built",
          "tooltip": "Select suggestion or press Enter"
        },
        {
          "id": "search-page",
          "title": "View Search Results",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/search"
        },
        {
          "id": "track-suggestion",
          "title": "Track Suggestion",
          "layer": "background",
          "status": "built",
          "tooltip": "trackSearchSuggestion() — fire and forget"
        }
      ]
    },
    {
      "id": "filter-and-browse",
      "title": "Filter & Browse Results",
      "trigger": "User reaches search or category results page",
      "steps": [
        {
          "id": "filter-panel",
          "title": "Open Filter Panel",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Filter: category, condition (6 tiers), price range, state, species, listing type, free shipping"
        },
        {
          "id": "url-params",
          "title": "Sync Filters to URL",
          "layer": "client",
          "status": "built",
          "tooltip": "All filters stored in URL params (shareable)"
        },
        {
          "id": "results-found",
          "title": "Check Results",
          "layer": "client",
          "status": "built",
          "tooltip": "Determines whether to show the results grid or an empty state"
        }
      ],
      "branches": [
        {
          "afterStep": "results-found",
          "condition": "Results found?",
          "paths": [
            { "label": "Yes", "goTo": "scroll-results" },
            {
              "label": "No (with filters)",
              "detail": "Empty state: 'Nothing here yet' + 'Try adjusting your filters or search terms.' + 'Clear all filters' button",
              "goTo": "END"
            },
            {
              "label": "No (no filters)",
              "detail": "Empty state: 'No results for \"{query}\"' + 'Try a different search term.' / 'Try different keywords or browse a category.' + 'Browse all listings' link",
              "goTo": "END"
            }
          ]
        }
      ],
      "connections": [
        { "from": "scroll-results", "to": "watch-from-card" },
        { "from": "scroll-results", "to": "listing-card-click" }
      ]
    },
    {
      "id": "filter-and-browse-results",
      "title": "Browse Result Grid",
      "trigger": "Results are returned on search or category page",
      "steps": [
        {
          "id": "scroll-results",
          "title": "Scroll Results",
          "action": "scroll",
          "layer": "client",
          "status": "built",
          "tooltip": "Infinite scroll pagination"
        },
        {
          "id": "watch-from-card",
          "title": "Watch from Card",
          "action": "click",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/listings/components/listing-card/index.tsx",
          "tooltip": "WatchButton overlaid on listing card image. Auth-gated — unauthenticated users are redirected to ?login=true. See member-watchlist.json for the full watch/unwatch flow."
        },
        {
          "id": "listing-card-click",
          "title": "Click Listing Card",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "listing-detail-page",
          "title": "View Listing Detail",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/listing/[id]"
        },
        {
          "id": "listing-view-count",
          "title": "Increment View Count",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/listings/[id]/view"
        },
        {
          "id": "recently-viewed",
          "title": "Track Recently Viewed",
          "layer": "background",
          "status": "built",
          "tooltip": "Recently viewed tracked in background"
        }
      ]
    },
    {
      "id": "view-profiles",
      "title": "View Seller & Shop Profiles",
      "trigger": "User clicks seller or shop link on listing detail",
      "steps": [
        {
          "id": "click-seller",
          "title": "Click Seller Link",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Click seller profile link on listing detail"
        },
        {
          "id": "member-page",
          "title": "View Seller Profile",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/member/[slug]"
        },
        {
          "id": "seller-listings",
          "title": "Browse Seller Items",
          "layer": "client",
          "status": "built",
          "tooltip": "See seller's other listings"
        },
        {
          "id": "click-shop",
          "title": "Click Shop Link",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Click shop page link on listing detail"
        },
        {
          "id": "shop-page",
          "title": "View Shop Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/shop/[slug]"
        },
        {
          "id": "shop-listings",
          "title": "Browse Shop Items",
          "layer": "client",
          "status": "built",
          "tooltip": "Shop's listings grid + hero banner"
        }
      ]
    }
  ]
}
