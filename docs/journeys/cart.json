{
  "slug": "cart",
  "domain": "cart",
  "title": "Cart (Guest + Authenticated)",
  "persona": "buyer",
  "description": "Cart system with dual storage: localStorage for guests, DB-backed with price snapshots for authenticated users. Includes merge on login, seller grouping, pre-checkout validation, and block enforcement.",
  "relatedIssues": [128, 129, 130, 324],
  "flows": [
    {
      "id": "add-to-cart",
      "title": "Add Item to Cart",
      "trigger": "User clicks 'Add to Cart' on listing detail page",
      "steps": [
        {
          "id": "click-add",
          "title": "Click Add to Cart",
          "action": "click",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/cart/components/add-to-cart-button/index.tsx",
          "errorCases": [
            {
              "condition": "Own listing",
              "result": "Button disabled"
            },
            {
              "condition": "Already in cart",
              "result": "Button shows 'In Cart'"
            },
            {
              "condition": "Cart has 25 items",
              "result": "Toast: cart full"
            }
          ]
        },
        {
          "id": "validate-client",
          "title": "Validate Cart State",
          "layer": "client",
          "status": "built",
          "tooltip": "Client-side validation: own listing, already in cart, cart full",
          "errorCases": [
            {
              "condition": "User's own listing",
              "result": "Button disabled"
            },
            {
              "condition": "Already in cart",
              "result": "Button shows 'In Cart'"
            },
            {
              "condition": "Cart has 25 items",
              "result": "Toast: cart full"
            }
          ]
        },
        {
          "id": "post-cart",
          "title": "Add to Cart (DB)",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/cart",
          "codeRef": "src/app/api/cart/route.ts",
          "tooltip": "Send listingId + priceCents. Server checks: listing exists + active, block check (isBlockedByServer), not own listing, no duplicate, cart cap.",
          "errorCases": [
            {
              "condition": "Seller has blocked the buyer",
              "result": "Returns 403 'You cannot purchase this listing'",
              "httpStatus": 403
            },
            {
              "condition": "Listing not found or inactive",
              "result": "Returns 404",
              "httpStatus": 404
            },
            {
              "condition": "Own listing",
              "result": "Returns 403",
              "httpStatus": 403
            },
            {
              "condition": "Already in cart",
              "result": "Returns 409",
              "httpStatus": 409
            },
            {
              "condition": "Cart full (25 items)",
              "result": "Returns 422",
              "httpStatus": 422
            }
          ]
        },
        {
          "id": "price-snapshot",
          "title": "Save Price Snapshot",
          "layer": "database",
          "status": "built",
          "tooltip": "Price snapshot saved as price_at_add"
        },
        {
          "id": "set-expiry",
          "title": "Set 30-Day Expiry",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "optimistic-update",
          "title": "Update Cache",
          "layer": "client",
          "status": "built",
          "tooltip": "Optimistic cache update"
        },
        {
          "id": "write-localstorage",
          "title": "Save to localStorage",
          "layer": "background",
          "status": "built",
          "tooltip": "Add item to localStorage cart (listingId + priceCents snapshot). No API calls."
        },
        {
          "id": "update-badge",
          "title": "Update Cart Badge",
          "layer": "client",
          "status": "built",
          "tooltip": "CartIcon badge count updates via Zustand store"
        },
        {
          "id": "show-toast",
          "title": "Show Added Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'Added to cart'"
        }
      ],
      "branches": [
        {
          "afterStep": "validate-client",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "Yes",
              "detail": "DB-backed: POST /api/cart with block check, price snapshot, 30-day expiry",
              "goTo": "post-cart"
            },
            {
              "label": "No",
              "detail": "Guest: save to localStorage",
              "goTo": "write-localstorage"
            }
          ]
        },
        {
          "afterStep": "set-expiry",
          "condition": "Auth path continues",
          "paths": [
            {
              "label": "Continue",
              "goTo": "optimistic-update"
            }
          ]
        },
        {
          "afterStep": "optimistic-update",
          "condition": "Auth path continues",
          "paths": [
            {
              "label": "Continue",
              "goTo": "show-toast"
            }
          ]
        },
        {
          "afterStep": "write-localstorage",
          "condition": "Guest path continues",
          "paths": [
            {
              "label": "Continue",
              "goTo": "update-badge"
            }
          ]
        },
        {
          "afterStep": "update-badge",
          "condition": "Guest path continues",
          "paths": [
            {
              "label": "Continue",
              "goTo": "show-toast"
            }
          ]
        }
      ]
    },
    {
      "id": "view-cart",
      "title": "View Cart",
      "trigger": "User navigates to /cart",
      "steps": [
        {
          "id": "check-auth",
          "title": "Check Auth State",
          "layer": "client",
          "status": "built",
          "tooltip": "Determine storage strategy: DB-backed for authenticated users, localStorage for guests"
        },
        {
          "id": "fetch-cart",
          "title": "Fetch Cart Items (DB)",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/cart",
          "tooltip": "Returns cart items joined with listing data"
        },
        {
          "id": "load-cart",
          "title": "Read localStorage Cart",
          "layer": "background",
          "status": "built"
        },
        {
          "id": "group-by-seller",
          "title": "Group by Seller",
          "layer": "client",
          "status": "built",
          "codeRef": "src/app/(frontend)/cart/page.tsx",
          "tooltip": "Items grouped by seller for display"
        },
        {
          "id": "show-item-states",
          "title": "Show Item States",
          "layer": "client",
          "status": "built",
          "tooltip": "States: valid, price changed (old vs new), removed/sold (warning)"
        },
        {
          "id": "show-items",
          "title": "Render Cart Items",
          "layer": "client",
          "status": "built",
          "tooltip": "Cart items with remove/clear actions. Checkout button disabled in MVP."
        },
        {
          "id": "cart-actions",
          "title": "Show Cart Actions",
          "layer": "client",
          "status": "built",
          "tooltip": "Actions: remove item, clear all, refresh expiry"
        }
      ],
      "branches": [
        {
          "afterStep": "check-auth",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "Yes",
              "detail": "Fetch from API",
              "goTo": "fetch-cart"
            },
            {
              "label": "No",
              "detail": "Read from localStorage",
              "goTo": "load-cart"
            }
          ]
        },
        {
          "afterStep": "fetch-cart",
          "condition": "Has items?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "group-by-seller"
            },
            {
              "label": "No",
              "detail": "Empty state + browse CTA",
              "goTo": "END"
            }
          ]
        },
        {
          "afterStep": "load-cart",
          "condition": "Has items?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "show-items"
            },
            {
              "label": "No",
              "detail": "Empty state: 'Your cart is empty' with 'Start Shopping' CTA",
              "goTo": "END"
            }
          ]
        },
        {
          "afterStep": "group-by-seller",
          "condition": "Auth path continues",
          "paths": [
            {
              "label": "Continue",
              "goTo": "show-item-states"
            }
          ]
        },
        {
          "afterStep": "show-item-states",
          "condition": "Auth path continues",
          "paths": [
            {
              "label": "Continue",
              "goTo": "cart-actions"
            }
          ]
        }
      ],
      "connections": [
        {
          "from": "cart-actions",
          "to": "remove-item",
          "label": "Remove"
        },
        {
          "from": "cart-actions",
          "to": "clear-all",
          "label": "Clear"
        },
        {
          "from": "cart-actions",
          "to": "refresh-expiry",
          "label": "Refresh"
        }
      ]
    },
    {
      "id": "cart-actions",
      "title": "Cart Item Actions",
      "trigger": "Buyer interacts with cart items",
      "steps": [
        {
          "id": "remove-item",
          "title": "Remove Item",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/[id]"
        },
        {
          "id": "clear-all",
          "title": "Clear All Items",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/cart"
        },
        {
          "id": "refresh-expiry",
          "title": "Refresh Expiry",
          "method": "PATCH",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/[id]/expiry"
        }
      ]
    },
    {
      "id": "merge-on-login",
      "title": "Cart Merge on Login",
      "trigger": "Guest logs in with items in localStorage cart",
      "steps": [
        {
          "id": "login-detected",
          "title": "Detect Auth Change",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/cart/hooks/use-cart-merge.ts",
          "tooltip": "useCartMerge() detects auth state change. Background hook — user sees nothing."
        },
        {
          "id": "read-guest-cart",
          "title": "Read Guest Cart",
          "layer": "background",
          "status": "built",
          "tooltip": "Read localStorage cart items"
        },
        {
          "id": "post-merge",
          "title": "Merge Cart to DB",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/merge",
          "tooltip": "Server validates every guest item: listing exists, not sold, not own listing, not already in DB cart."
        },
        {
          "id": "server-validate",
          "title": "Skip Invalid Items",
          "layer": "server",
          "status": "built",
          "tooltip": "Invalid/duplicate/own-listing items silently dropped. No errors surfaced to user."
        },
        {
          "id": "insert-valid",
          "title": "Insert Valid Items",
          "layer": "database",
          "status": "built",
          "tooltip": "Insert valid items into cart table"
        },
        {
          "id": "clear-localstorage",
          "title": "Clear Guest Cart",
          "layer": "background",
          "status": "built",
          "tooltip": "Clear localStorage guest cart. No toast, no redirect. Cart page now shows DB-backed items."
        }
      ]
    },
    {
      "id": "pre-checkout-validation",
      "title": "Pre-Checkout Validation",
      "trigger": "Buyer initiates checkout",
      "steps": [
        {
          "id": "validate-cart",
          "title": "Validate Cart",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/validate",
          "codeRef": "src/features/cart/services/cart-server.ts",
          "tooltip": "Validates all cart items. Batch block check: single IN query on member_blocks for all unique seller IDs. Blocked items moved to removed[] with reason: 'blocked'."
        },
        {
          "id": "handle-result",
          "title": "Handle Result",
          "layer": "client",
          "status": "built",
          "tooltip": "Handle validation result"
        },
        {
          "id": "ready-for-checkout",
          "title": "Cart Ready",
          "layer": "client",
          "status": "built",
          "tooltip": "Items render in seller-grouped sections. Checkout button enabled."
        },
        {
          "id": "price-change-notice",
          "title": "Show Price Change",
          "layer": "client",
          "status": "planned",
          "tooltip": "Price change UI not yet implemented. Validation detects changes but cart page does not display them.",
          "notes": "Gap: validation API returns price changes but cart-page.tsx only handles removed items"
        },
        {
          "id": "show-removed-banner",
          "title": "Show Removed Banner",
          "layer": "client",
          "status": "built",
          "tooltip": "Stale banner: \"{count} items were removed\" with per-item reasons (Sold, Deactivated, Unavailable). Dismiss button. Items auto-removed from cart."
        }
      ],
      "branches": [
        {
          "afterStep": "validate-cart",
          "condition": "Validation result?",
          "paths": [
            {
              "label": "Valid",
              "detail": "Proceed to checkout",
              "goTo": "ready-for-checkout"
            },
            {
              "label": "Price Changed",
              "detail": "Acknowledge price changes",
              "goTo": "price-change-notice"
            },
            {
              "label": "Removed (sold/deleted/deactivated/blocked)",
              "detail": "Items auto-removed from cart. Blocked items show same UX as other removals.",
              "goTo": "show-removed-banner"
            }
          ]
        }
      ]
    }
  ]
}
