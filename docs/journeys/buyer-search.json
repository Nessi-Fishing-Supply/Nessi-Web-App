          "label": "Suggestions from popular search terms, listing titles, category names",
          "layer": "server",
          "status": "built"
        },
        {
          "id": "select-or-enter",
          "label": "Select suggestion or press Enter",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "search-page",
          "label": "Navigate to /search?q=...",
          "layer": "client",
          "status": "built",
          "route": "/search"
        },
        {
          "id": "track-suggestion",
          "label": "trackSearchSuggestion() — fire and forget",
          "layer": "background",
          "status": "built"
        }
      ]
    },
    {
