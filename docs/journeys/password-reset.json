{
  "slug": "password-reset",
  "title": "Password Reset (3-Step OTP)",
  "persona": "auth",
  "description": "User resets forgotten password via a 3-step flow: enter email, verify OTP code, set new password.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "reset-password",
      "title": "Forgot Password → OTP → New Password",
      "trigger": "User visits /auth/reset-password",
      "steps": [
        {
          "id": "visit-page",
          "label": "User visits /auth/reset-password",
          "layer": "client",
          "status": "built",
          "route": "/auth/reset-password"
        },
        {
          "id": "enter-email",
          "label": "Step 1: Enter email address",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "send-otp",
          "label": "forgotPassword(email) — OTP sent to email",
          "layer": "server",
          "status": "built"
        },
        {
          "id": "enter-otp",
          "label": "Step 2: Enter 6-digit code from email",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "verify-otp",
          "label": "verifyOtp(type='recovery')",
          "layer": "server",
          "status": "built",
          "errorCases": [
            { "condition": "Invalid/expired code", "result": "Show error, allow retry" }
          ]
        },
        {
          "id": "enter-new-password",
          "label": "Step 3: Enter new password",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "reset-password",
          "label": "resetPassword(newPassword)",
          "layer": "server",
          "status": "built"
        },
        {
          "id": "session-established",
          "label": "Session established via cookies",
          "layer": "server",
          "status": "built"
        },
        {
          "id": "redirect-home",
          "label": "Redirect to /",
          "layer": "client",
          "status": "built"
        }
      ],
      "branches": [
        {
          "afterStep": "verify-otp",
          "condition": "OTP valid?",
          "paths": [
            { "label": "Yes", "goTo": "enter-new-password" },
            { "label": "No — show error, allow retry", "goTo": "enter-otp" }
          ]
        }
      ]
    }
  ]
}
